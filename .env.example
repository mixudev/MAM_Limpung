APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mam_limpung
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
# lax diperlukan agar session cookie terbawa saat redirect balik dari Google OAuth2
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=email@sekolah.ac.id
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_FROM_ADDRESS="no-reply@mamlimpung.sch.id"
MAIL_FROM_NAME="${APP_NAME}"
# Untuk Gmail: MAIL_SCHEME=null, MAIL_PORT=587, gunakan App Password di MAIL_PASSWORD
# Untuk SSL: MAIL_SCHEME=ssl, MAIL_PORT=465

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google Drive OAuth2 (untuk backup ke Google Drive personal)
# Dapatkan dari: https://console.cloud.google.com/ → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_DRIVE_OAUTH2_CLIENT_ID=
GOOGLE_DRIVE_OAUTH2_CLIENT_SECRET=

# Kunci enkripsi yang digunakan untuk backup sistem
BACKUP_ENCRYPTION_KEY=
